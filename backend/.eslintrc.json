{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json",
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "rules": {
    "no-console": "error",
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_" }
    ]
  },
  "ignorePatterns": ["src/**/*.test.ts", "src/**/__tests__/**", "src/services/campaignController.ts"],
  "overrides": [
    {
      "files": ["**/*.test.ts", "tests/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
