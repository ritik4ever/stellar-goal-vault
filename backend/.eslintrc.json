{
  "root": true,
  "ignorePatterns": ["src/services/campaignController.ts"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {

    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "rules": {
    "no-console": "error"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "tests/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
